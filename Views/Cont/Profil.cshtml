@model Proiect_ASPDOTNET.Models.Entities.User

@{
    ViewData["Title"] = "Profilul Meu";
}

<div class="mb-4">
    <h2><i class="fas fa-user me-2"></i>Profilul Meu</h2>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-info-circle me-2"></i>Informatii Personale</span>
                <a href="/Cont/EditareProfil" class="btn btn-sm btn-warning">
                    <i class="fas fa-edit me-1"></i>Editeaza
                </a>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4 text-muted">ID Utilizator:</div>
                    <div class="col-md-8"><code>@Model.UserId</code></div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4 text-muted">Nume Complet:</div>
                    <div class="col-md-8"><strong>@Model.NumeComplet</strong></div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4 text-muted">Username:</div>
                    <div class="col-md-8">@Model.Username</div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4 text-muted">Email:</div>
                    <div class="col-md-8">@Model.Email</div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4 text-muted">Rol:</div>
                    <div class="col-md-8">
                        @if (Model.Rol == Proiect_ASPDOTNET.Models.Entities.UserRole.SuperAdmin)
                        {
                            <span class="badge bg-danger">SuperAdmin</span>
                        }
                        else if (Model.Rol == Proiect_ASPDOTNET.Models.Entities.UserRole.DirectorCompanie)
                        {
                            <span class="badge bg-primary">Director Companie</span>
                        }
                        else if (Model.Rol == Proiect_ASPDOTNET.Models.Entities.UserRole.ResponsabilDepozit)
                        {
                            <span class="badge bg-info">Responsabil Depozit</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Muncitor</span>
                        }
                    </div>
                </div>
                @if (Model.Companie != null)
                {
                    <div class="row mb-3">
                        <div class="col-md-4 text-muted">Companie:</div>
                        <div class="col-md-8">@Model.Companie.Nume</div>
                    </div>
                }
                @if (Model.Depozit != null)
                {
                    <div class="row mb-3">
                        <div class="col-md-4 text-muted">Depozit:</div>
                        <div class="col-md-8">@Model.Depozit.Nume</div>
                    </div>
                }
                @if (Model.Rol == Proiect_ASPDOTNET.Models.Entities.UserRole.Muncitor)
                {
                    <div class="row mb-3">
                        <div class="col-md-4 text-muted">Puncte Reward:</div>
                        <div class="col-md-8">
                            <span class="badge bg-warning text-dark fs-6">
                                <i class="fas fa-star me-1"></i>@Model.PuncteReward puncte
                            </span>
                        </div>
                    </div>
                }
                <div class="row">
                    <div class="col-md-4 text-muted">Data Creare Cont:</div>
                    <div class="col-md-8">@Model.DataCreare.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-cog me-2"></i>Actiuni
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="/Cont/EditareProfil" class="btn btn-primary">
                        <i class="fas fa-user-edit me-2"></i>Editeaza Profil
                    </a>
                    <a href="/Cont/SchimbareParola" class="btn btn-warning">
                        <i class="fas fa-key me-2"></i>Schimba Parola
                    </a>
                    <a href="/Dashboard/Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Inapoi la Dashboard
                    </a>
                </div>
            </div>
        </div>

        <div class="card mt-3 bg-light">
            <div class="card-body">
                <h6><i class="fas fa-info-circle me-2"></i>Informatii Securitate</h6>
                <p class="small mb-2">
                    <i class="fas fa-check text-success me-1"></i> Poti schimba username-ul
                </p>
                <p class="small mb-2">
                    <i class="fas fa-check text-success me-1"></i> Poti schimba parola
                </p>
                <p class="small mb-0">
                    <i class="fas fa-lock text-warning me-1"></i> Rolul se modifica doar de administratori
                </p>
            </div>
        </div>
    </div>
</div>