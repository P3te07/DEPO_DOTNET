@model Proiect_ASPDOTNET.Models.ViewModels.ResponsabilDepozitDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Responsabil";
}

<div class="mb-4">
    <h2><i class="fas fa-warehouse me-2"></i>Dashboard Responsabil Depozit</h2>
    <p class="text-muted">@Model.Depozit.Nume - @Model.Depozit.Companie.Nume</p>
</div>

<!-- Statistici -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h6 class="card-title">Total Produse</h6>
                <h2 class="mb-0">@Model.TotalMarfuri</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h6 class="card-title">Valoare Totala</h6>
                <h2 class="mb-0">@Model.ValoareTotala.ToString("N0") MDL</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h6 class="card-title">Tranzactii Recente</h6>
                <h2 class="mb-0">@Model.TranzactiiRecente.Count</h2>
            </div>
        </div>
    </div>
</div>

<!-- Actiuni Rapide -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-tasks me-2"></i>Actiuni Rapide
            </div>
            <div class="card-body">
                <div class="btn-group" role="group">
                    <a href="/Marfa/Create" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Adauga Marfa
                    </a>
                    <a href="/Tranzactie/Create" class="btn btn-success">
                        <i class="fas fa-arrow-down me-2"></i>Intrare Marfa
                    </a>
                    <a href="/Tranzactie/Create" class="btn btn-warning">
                        <i class="fas fa-arrow-up me-2"></i>Iesire Marfa
                    </a>
                    <a href="/Rapoarte/Inventar?depozitId=@Model.Depozit.Id" class="btn btn-info text-white">
                        <i class="fas fa-file-alt me-2"></i>Raport Inventar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabel Inventar -->
<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-boxes me-2"></i>Inventar Depozit (Top 10 Produse)
    </div>
    <div class="card-body">
        @if (Model.Marfuri.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>SKU</th>
                            <th>Nume Produs</th>
                            <th>Cantitate</th>
                            <th>Localizare</th>
                            <th>Pret Unitar</th>
                            <th>Valoare Totala</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var marfa in Model.Marfuri.Take(10))
                        {
                            <tr>
                                <td><code>@marfa.SKU</code></td>
                                <td><strong>@marfa.Nume</strong></td>
                                <td><span class="badge bg-info">@marfa.CantitateCurenta @marfa.UnitateMasura</span></td>
                                <td>
                                    <small>
                                        Zona <strong>@marfa.Zona</strong>,
                                        Etaj <strong>@marfa.Etaj</strong>,
                                        Raft <strong>@marfa.Raft-@marfa.Pozitie</strong>
                                    </small>
                                </td>
                                <td>@marfa.PretUnitar.ToString("N2") MDL</td>
                                <td><strong>@((marfa.CantitateCurenta * marfa.PretUnitar).ToString("N2")) MDL</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="text-center mt-3">
                <a href="/Marfa/Index" class="btn btn-outline-primary">Vezi Tot Inventarul</a>
            </div>
        }
        else
        {
            <p class="text-muted text-center mb-0">Nu exista marfuri in depozit.</p>
        }
    </div>
</div>

<!-- Tranzactii Recente -->
<div class="card">
    <div class="card-header">
        <i class="fas fa-history me-2"></i>Tranzactii Recente
    </div>
    <div class="card-body">
        @if (Model.TranzactiiRecente.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Tip</th>
                            <th>Marfa</th>
                            <th>Cantitate</th>
                            <th>Utilizator</th>
                            <th>Valoare</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tranzactie in Model.TranzactiiRecente)
                        {
                            <tr>
                                <td>@tranzactie.DataTranzactie.ToString("dd.MM HH:mm")</td>
                                <td>
                                    @if (tranzactie.Tip == Proiect_ASPDOTNET.Models.Entities.TipTranzactie.Intrare)
                                    {
                                        <span class="badge bg-success">Intrare</span>
                                    }
                                    else if (tranzactie.Tip == Proiect_ASPDOTNET.Models.Entities.TipTranzactie.Iesire)
                                    {
                                        <span class="badge bg-warning">Iesire</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">Transfer</span>
                                    }
                                </td>
                                <td>@tranzactie.Marfa.Nume</td>
                                <td>@tranzactie.Cantitate</td>
                                <td>@tranzactie.User.NumeComplet</td>
                                <td>@tranzactie.ValoareTotala.ToString("N2") MDL</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted text-center mb-0">Nu exista tranzactii recente.</p>
        }
    </div>
</div>