@model Proiect_ASPDOTNET.Models.ViewModels.SuperAdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard SuperAdmin";
}

<div class="mb-4">
    <h2><i class="fas fa-chart-line me-2"></i>Dashboard SuperAdmin</h2>
    <p class="text-muted">Privire de ansamblu asupra sistemului</p>
</div>

<!-- Statistici Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Total Companii</h6>
                        <h2 class="mb-0">@Model.TotalCompanii</h2>
                    </div>
                    <i class="fas fa-building fa-3x opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a href="/Companie/Index" class="text-white text-decoration-none">
                    Vezi toate <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Total Depozite</h6>
                        <h2 class="mb-0">@Model.TotalDepozite</h2>
                    </div>
                    <i class="fas fa-warehouse fa-3x opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a href="/Depozit/Index" class="text-white text-decoration-none">
                    Vezi toate <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Total Utilizatori</h6>
                        <h2 class="mb-0">@Model.TotalUtilizatori</h2>
                    </div>
                    <i class="fas fa-users fa-3x opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a href="/User/Index" class="text-white text-decoration-none">
                    Vezi toti <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Total Tranzactii</h6>
                        <h2 class="mb-0">@Model.TotalTranzactii</h2>
                    </div>
                    <i class="fas fa-exchange-alt fa-3x opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a href="/Tranzactie/Index" class="text-white text-decoration-none">
                    Vezi toate <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Grafic Crestere Companii -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-chart-line me-2"></i>Evolutie Companii (Ultimele 12 Luni)
            </div>
            <div class="card-body">
                <canvas id="companiiChart" height="100"></canvas>
            </div>
        </div>

        <!-- Companii Recente -->
        <div class="card mt-4">
            <div class="card-header">
                <i class="fas fa-building me-2"></i>Companii Recente
            </div>
            <div class="card-body">
                @if (Model.CompaniiRecente.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>ID Companie</th>
                                    <th>Nume</th>
                                    <th>CUI</th>
                                    <th>Data Inregistrare</th>
                                    <th>Status</th>
                                    <th>Actiuni</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var companie in Model.CompaniiRecente)
                                {
                                    <tr>
                                        <td><code>@companie.CompanieId</code></td>
                                        <td><strong>@companie.Nume</strong></td>
                                        <td>@companie.CUI</td>
                                        <td>@companie.DataInregistrare.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            @if (companie.Active)
                                            {
                                                <span class="badge bg-success">Activa</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactiva</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="/Companie/Details/@companie.Id" class="btn btn-sm btn-outline-info">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center mb-0">Nu exista companii inregistrate.</p>
                }
            </div>
        </div>
    </div>

    <!-- Actiuni Rapide -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-tasks me-2"></i>Actiuni Rapide
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="/Companie/Create" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Adauga Companie
                    </a>
                    <a href="/Depozit/Create" class="btn btn-success">
                        <i class="fas fa-warehouse me-2"></i>Adauga Depozit
                    </a>
                    <a href="/User/Create" class="btn btn-info text-white">
                        <i class="fas fa-user-plus me-2"></i>Adauga Utilizator
                    </a>
                    <a href="/Rapoarte/Index" class="btn btn-warning text-white">
                        <i class="fas fa-file-alt me-2"></i>Vezi Rapoarte
                    </a>
                </div>
            </div>
        </div>

        <!-- Statistici Suplimentare -->
        <div class="card mt-4">
            <div class="card-header">
                <i class="fas fa-info-circle me-2"></i>Statistici Sistem
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Companii Active</small>
                        <small class="text-muted">@Model.TotalCompanii</small>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-primary" style="width: 100%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Depozite Active</small>
                        <small class="text-muted">@Model.TotalDepozite</small>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-success" style="width: 100%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Utilizatori Activi</small>
                        <small class="text-muted">@Model.TotalUtilizatori</small>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-info" style="width: 100%"></div>
                    </div>
                </div>

                <div>
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Tranzactii Totale</small>
                        <small class="text-muted">@Model.TotalTranzactii</small>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-warning" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Info Card -->
        <div class="card mt-4 bg-light">
            <div class="card-body">
                <h6 class="card-title"><i class="fas fa-lightbulb me-2"></i>Sfat</h6>
                <p class="card-text small mb-0">
                    Foloseste sectiunea de rapoarte pentru a analiza in detaliu activitatea companiilor si depozitelor.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Prepare data for chart
        var chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CrestereCompanii));

        var ctx = document.getElementById('companiiChart').getContext('2d');
        var chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: chartData.map(d => d.luna),
                datasets: [{
                    label: 'Numar Companii',
                    data: chartData.map(d => d.numarCompanii),
                    backgroundColor: 'rgba(52, 152, 219, 0.2)',
                    borderColor: 'rgba(52, 152, 219, 1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        mode: 'index',
                        intersect: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                },
                interaction: {
                    mode: 'nearest',
                    axis: 'x',
                    intersect: false
                }
            }
        });
    </script>
}