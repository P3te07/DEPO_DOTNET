@model Proiect_ASPDOTNET.Models.ViewModels.DirectorCompanieDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Director";
}

<div class="mb-4">
    <h2><i class="fas fa-briefcase me-2"></i>Dashboard Director Companie</h2>
    <p class="text-muted">@Model.Companie.Nume</p>
</div>

<!-- Info Companie -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-building me-2"></i>Informatii Companie
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>Nume:</strong> @Model.Companie.Nume</p>
                <p class="mb-2"><strong>CUI:</strong> @Model.Companie.CUI</p>
                <p class="mb-2"><strong>Email:</strong> @Model.Companie.Email</p>
                <p class="mb-0"><strong>Adresa:</strong> @Model.Companie.Adresa</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h6 class="card-title">Valoare Totala Inventar</h6>
                <h2 class="mb-0">@Model.ValoareTotala.ToString("N0") MDL</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h6 class="card-title">Total Tranzactii</h6>
                <h2 class="mb-0">@Model.TotalTranzactii</h2>
            </div>
        </div>
    </div>
</div>

<!-- Harta Depozite -->
<!-- Harta Depozite -->
<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-map-marked-alt me-2"></i>Localizare Depozite
    </div>
    <div class="card-body">
        <div id="map" style="height: 400px; border-radius: 8px;"></div>
    </div>
</div>

@section Scripts {
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        // Initialize map
        var map = L.map('map').setView([47.0105, 28.8638], 12); 
        
        // Add OpenStreetMap tiles
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19
        }).addTo(map);
        
        // Add markers for each depot
        var depozite = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Depozite.Select(d => new {
            nume = d.Depozit.Nume,
            lat = d.Depozit.Latitudine,
            lng = d.Depozit.Longitudine,
            adresa = d.Depozit.Adresa,
            marfuri = d.NumarMarfuri,
            valoare = d.ValoareDepozit.ToString("N2")
        })));
        
        var markers = [];
        
        depozite.forEach(function(depozit) {
            var marker = L.marker([parseFloat(depozit.lat), parseFloat(depozit.lng)])
                .addTo(map)
                .bindPopup(`
                    <div style="min-width: 200px;">
                        <h6 class="mb-2"><i class="fas fa-warehouse me-2"></i>${depozit.nume}</h6>
                        <p class="mb-1 small"><i class="fas fa-map-marker-alt me-2"></i>${depozit.adresa}</p>
                        <p class="mb-1 small"><i class="fas fa-boxes me-2"></i>${depozit.marfuri} produse</p>
                        <p class="mb-0 small"><i class="fas fa-dollar-sign me-2"></i>${depozit.valoare} MDL</p>
                    </div>
                `);
            markers.push(marker);
        });
        
        // Fit bounds to show all markers
        if (markers.length > 0) {
            var group = new L.featureGroup(markers);
            map.fitBounds(group.getBounds().pad(0.1));
        }
    </script>
}
<!-- Tabel Depozite -->
<div class="card">
    <div class="card-header">
        <i class="fas fa-warehouse me-2"></i>Depozite (@Model.Depozite.Count)
    </div>
    <div class="card-body">
        @if (Model.Depozite.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Nume Depozit</th>
                            <th>Adresa</th>
                            <th>Numar Marfuri</th>
                            <th>Valoare Depozit</th>
                            <th>Tranzactii</th>
                            <th>Actiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var depozit in Model.Depozite)
                        {
                            <tr>
                                <td><strong>@depozit.Depozit.Nume</strong></td>
                                <td>@depozit.Depozit.Adresa</td>
                                <td><span class="badge bg-primary">@depozit.NumarMarfuri produse</span></td>
                                <td><strong>@depozit.ValoareDepozit.ToString("N2") MDL</strong></td>
                                <td><span class="badge bg-info">@depozit.NumarTranzactii</span></td>
                                <td>
                                    <a href="/Depozit/Details/@depozit.Depozit.Id" class="btn btn-sm btn-outline-info">
                                        <i class="fas fa-eye"></i> Vezi Detalii
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-active">
                        <tr>
                            <td colspan="3" class="text-end"><strong>TOTAL:</strong></td>
                            <td><strong>@Model.ValoareTotala.ToString("N2") MDL</strong></td>
                            <td><strong>@Model.TotalTranzactii tranzactii</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted text-center mb-0">Nu exista depozite pentru aceasta companie.</p>
        }
    </div>
</div>